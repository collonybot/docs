{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "aspen",
  "name": "collony.ai",
  "description": "collony – AI moderation for Telegram and Discord communities.",
  "colors": {
    "primary": "#0ea5e9",
    "light": "#EDEDF0",
    "dark": "#0F0F15"
  },
  "favicon": "/public/favicon.png",
  "logo": {
    "light": "/public/darklogo.png",
    "dark": "/public/lightlogo.png"
  },
  "topbarCtaButton": {
    "name": "Get Started",
    "url": "https://collony.ai"
  },
  "navigation": {
    "groups": [
      {
        "group": "Getting Started",
        "pages": [
          "introduction",
          "login",
          "projects",
          "billing"
        ]
      },
      {
        "group": "Configuration",
        "pages": [
          "bot-setup",
          "channels",
          "schedule",
          "settings"
        ]
      },
      {
        "group": "Moderation",
        "pages": [
          "incidents",
          "chat-history",
          "members",
          "member-details"
        ]
      },
      {
        "group": "Analytics",
        "pages": [
          "overview",
          "sentiment",
          "activity"
        ]
      }
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/collonybot",
      "telegram": "https://t.me/collony_official",
      "linkedin": "https://www.linkedin.com/company/collony",
      "website": "https://collony.ai"
    }
  },
  "background": {
    "color": {
      "light": "#EDEDF0",
      "dark": "#0F0F15"
    },
    "decoration": "grid"
  },
  "fonts": {
    "family": "Geist"
  },
  "appearance": {
    "strict": false
  },
  "icons": {
    "library": "fontawesome"
  },
  "navbar": {
    "links": []
  },
  "metadata": {
    "timestamp": true
  },
  "contextual": {
    "options": [
      "copy",
      "assistant"
    ],
    "display": "header"
  },
  "search": {
    "prompt": "Search docs..."
  },
  "thumbnails": {
    "appearance": "light",
    "background": "/images/thumbnailbg.png",
    "fonts": {
      "family": "Geist"
    }
  }
}
