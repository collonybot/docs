{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "aspen",
  "name": "collony.ai",
  "description": "AI-powered moderation and community intelligence for Telegram and Discord.",
  "colors": {
    "primary": "#0073E6",
    "light": "#4A97F0",
    "dark": "#0066CC"
  },
  "favicon": "/public/favicon.png",
  "logo": {
    "light": "/public/darklogo.png",
    "dark": "/public/lightlogo.png"
  },
  "topbarCtaButton": {
    "name": "Get Started",
    "url": "https://collony.ai"
  },
  "navigation": {
    "groups": [
      {
        "group": "Getting Started",
        "pages": [
          "introduction",
          "login",
          "projects",
          "billing"
        ]
      },
      {
        "group": "Configuration",
        "pages": [
          "bot-setup",
          "channels",
          "schedule",
          "settings"
        ]
      },
      {
        "group": "Moderation",
        "pages": [
          "incidents",
          "chat-history",
          "members",
          "member-details"
        ]
      },
      {
        "group": "Analytics",
        "pages": [
          "overview",
          "sentiment",
          "activity"
        ]
      }
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/collonybot",
      "telegram": "https://t.me/collony_official",
      "linkedin": "https://www.linkedin.com/company/collony",
      "website": "https://www.collony.ai/",
      "discord": "https://discord.gg/na6xcu7xV7"
    }
  },
  "background": {
    "color": {
      "light": "#F4F4FA",
      "dark": "#08080B"
    }
  },
  "fonts": {
    "family": "Geist"
  },
  "appearance": {
    "strict": false
  },
  "icons": {
    "library": "lucide"
  },
  "navbar": {
    "links": []
  },
  "metadata": {
    "timestamp": true
  },
  "contextual": {
    "options": [
      "copy",
      "assistant"
    ],
    "display": "header"
  },
  "search": {
    "prompt": "Search docs..."
  },
  "thumbnails": {
    "background": "/images/thumbnailbg.png",
    "fonts": {
      "family": "Geist"
    },
    "appearance": "light"
  },
  "errors": {
    "404": {
      "redirect": true
    }
  }
}
